{
  "name": "@calls-calendar/api-dto",
  "private": true,
  "version": "0.0.0",
  "exports": {
    "./generated": {
      "types": "./generated/api-types.ts",
      "default": "./generated/api-types.ts"
    }
  },
  "scripts": {
    "build": "pnpm generate:openapi && pnpm generate:types",
    "generate:openapi": "tsp compile .",
    "generate:types": "openapi-typescript ./dist/openapi/openapi.yaml -o ./generated/api-types.ts --root-types --root-types-no-schema-prefix --export-type",
    "lint": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json generated",
    "lint:staged": "oxlint --config .oxlintrc.json --tsconfig tsconfig.json generated",
    "test": "pnpm type-check",
    "type-check": "tsp compile . --no-emit && tsc -p tsconfig.json --noEmit --pretty false"
  },
  "devDependencies": {
    "@typespec/compiler": "^1.4.0",
    "@typespec/http": "^1.4.0",
    "@typespec/json-schema": "^1.4.0",
    "@typespec/openapi3": "^1.4.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5"
  }
}
