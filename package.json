{
  "name": "calls-calendar",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "turbo run build",
    "commitlint": "commitlint",
    "lint": "turbo run lint",
    "lint:precommit": "turbo run lint:precommit",
    "lint-staged": "lint-staged",
    "prepare": "git config core.hooksPath .githooks",
    "setup:hooks": "git config core.hooksPath .githooks",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "test:e2e": "pnpm --filter @calls-calendar/frontend test:e2e"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "lint-staged": "17.0.7",
    "oxlint": "1.70.0",
    "prettier": "^3.5.0",
    "turbo": "^2.9.14"
  }
}
