{
  "name": "@calls-calendar/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm generate:contract-schemas && tsc -p tsconfig.build.json && pnpm generate:prism",
    "dev": "tsx watch src/server.ts",
    "generate:contract-schemas": "pnpm --filter @calls-calendar/api-dto generate:openapi && node ./scripts/build-contract-schemas.mjs",
    "generate:prism": "pnpm --filter @calls-calendar/api-dto generate:openapi && node ./scripts/build-prism-openapi.mjs",
    "lint": "echo \"backend lint is not configured yet\"",
    "mock": "pnpm generate:prism && prism mock ./dist/prism/openapi.mock.yaml -h 127.0.0.1 -p 4010",
    "start": "node dist/server.js",
    "test": "pnpm generate:contract-schemas && vitest run"
  },
  "devDependencies": {
    "@calls-calendar/api-dto": "workspace:^",
    "@stoplight/prism-cli": "^5.15.10",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1",
    "fastify": "^5.8.5"
  }
}
